# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── DEPENDENCIES ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── TESTING ──────────────────────────────────────────────────────────────────
/coverage

# ─── NEXT.JS ──────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── PRODUCTION ───────────────────────────────────────────────────────────────
/build

# ─── ENV & SECRETS ────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.development
!.env.example

# ─── DATABASE / PRISMA ────────────────────────────────────────────────────────
/app/generated/prisma
/prisma/migrations/
*.db
*.sqlite
*.sqlite3
*.dump
*.sql

# ─── UPLOADS & USER DATA ─────────────────────────────────────────────────────
/uploads/

# ─── SCRIPTS WITH SENSITIVE DATA ─────────────────────────────────────────────
/scripts/excel-data.json

# ─── BACKUP FILES ─────────────────────────────────────────────────────────────
*.bak
/backup_ui/

# ─── IDE & EDITOR ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.claude/
.gemini/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── DEBUG LOGS ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── VERCEL ───────────────────────────────────────────────────────────────────
.vercel

# ─── TYPESCRIPT BUILD INFO ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
