# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/inventrack"

# Docker Compose DB credentials (used by docker-compose.yml)
POSTGRES_USER="inventrack"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="inventrack"

# ─── AUTH ──────────────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_TRUST_HOST=true

# Admin credentials (seeded once)
ADMIN_EMAIL="admin@company.com"
ADMIN_PASSWORD_HASH="bcrypt-hash-here"
# Generate hash: npx bcryptjs hash "your-password"

# ─── FILE STORAGE ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ─── ENCRYPTION ────────────────────────────────────────────────────────────────
# 32-character hex key for AES-256-GCM encryption of subscription credentials
ENCRYPTION_KEY="32-char-hex-key-here"

# ─── SMTP (Optional) ──────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── ALERTS ────────────────────────────────────────────────────────────────────
ALERT_DAYS_AHEAD=30
